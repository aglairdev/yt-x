STATE_CURRENT_CHANNEL_RESULTS_URL='$(printf "%s" "$STATE_CURRENT_CHANNEL_RESULTS_URL" | sed "s/'/'\\\\''/g")'
STATE_CURRENT_CHANNEL_RESULTS_START='$STATE_CURRENT_CHANNEL_RESULTS_START'
