STATE_CURRENT_CHANNEL_URL='$(printf "%s" "$STATE_CURRENT_CHANNEL_URL" | sed "s/'/'\\\\''/g")'
STATE_CURRENT_CHANNEL_TITLE='$(printf "%s" "$STATE_CURRENT_CHANNEL_TITLE" | sed "s/'/'\\\\''/g")'

