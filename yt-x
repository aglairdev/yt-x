      nohup $vlc_cmd "$url" $opts &
    else
      # shellcheck disable=SC2086
      $vlc_cmd "$url" $opts
    fi
    ;;
  esac

  # shellcheck disable=SC2181
  if [ "$?" = "0" ]; then
