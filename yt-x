STATE_CURRENT_PLAYLISTS_RESULTS_START='$STATE_CURRENT_PLAYLISTS_RESULTS_START'
STATE_CURRENT_PLAYLISTS_RESULTS_END='$STATE_CURRENT_PLAYLISTS_RESULTS_END'

